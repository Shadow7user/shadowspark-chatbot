# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/shadowspark_chatbot?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/shadowspark_chatbot?sslmode=require"

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID="123456789012345"
WHATSAPP_TOKEN="your-meta-cloud-api-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
# Legacy fallback accepted by the code:
# WHATSAPP_ACCESS_TOKEN="your-meta-cloud-api-token"

# OpenAI
OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"         # default: gpt-4o-mini
# OPENAI_MAX_TOKENS=500              # default: 500
# OPENAI_TEMPERATURE=0.7             # default: 0.7

# Redis (BullMQ queue)
REDIS_URL="redis://localhost:6379"

# Upstash Redis REST (optional session store)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# DEFAULT_CLIENT_ID="shadowspark-demo"  # default: shadowspark-demo

# Webhook (your deployed URL — Railway, ngrok for local dev)
WEBHOOK_BASE_URL="https://your-app.up.railway.app"

# Admin (optional — protects /setup/* endpoints)
# ADMIN_SECRET="your-secret-at-least-16-chars"
